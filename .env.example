# Copy to .env and fill in for production. In development, missing values are auto-generated
# ephemerally (with a warning) so `pnpm dev` works out of the box — never rely on that in production.

NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# Set to true ONLY once a reverse proxy (Caddy/nginx/Traefik) in front of this process actually
# terminates TLS. Independent of NODE_ENV on purpose — a production deployment can validly run
# over plain HTTP for a while (e.g. LAN-only, no proxy set up yet), and this gates both the
# Secure cookie flag and CSP's upgrade-insecure-requests. Leaving it false when there's no TLS is
# correct, not a downgrade: setting it true without real TLS in front breaks the app outright
# (login cookies won't be sent, and every asset request gets rewritten to https and fails).
TLS_TERMINATED=false

# 64 hex chars (32 bytes). Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ENCRYPTION_KEY=
COOKIE_SECRET=

# One-time token used to register the very first Proxmox cluster before any app-admin exists.
# Set it, register your first cluster, then remove it.
SETUP_TOKEN=

# Comma-separated Proxmox identities (user@realm) allowed to manage the cluster registry & settings.
APP_ADMIN_USERS=root@pam

DATABASE_PATH=./data/app.sqlite

# Leave unset for same-origin deployment (recommended). Only set if the web UI is served from a
# different origin than the API.
CORS_ORIGIN=
