{
  "name": "proxmox-modern-ui",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "A modern, secure, open-source management UI for Proxmox VE",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter ./apps/* run dev",
    "build": "pnpm --recursive run build",
    "lint": "pnpm --recursive run lint",
    "typecheck": "pnpm --recursive run typecheck",
    "test": "pnpm --recursive run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.18.1",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "selfsigned": "^2.4.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.19.0",
    "ws": "^8.21.0"
  },
  "packageManager": "pnpm@11.9.0"
}
